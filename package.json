{
  "name": "adaptive-slide",
  "version": "0.2.0",
  "description": "A schema-driven presentation builder/viewer built on Adaptive Cards with MCP App support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "adaptive-slide-server": "./dist/plugins/mcp-app/server.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node scripts/copy-assets.js",
    "docs:build": "docusaurus build website --config docusaurus.config.cjs",
    "docs:deploy": "node scripts/deploy-docs.js",
    "docs:serve": "docusaurus serve website/build",
    "docs:start": "docusaurus start website --config docusaurus.config.cjs",
    "validate": "node scripts/validate.js",
    "test": "node --test tests/*.test.js",
    "lint": "tsc --noEmit",
    "serve": "node dist/plugins/mcp-app/server.js",
    "dev": "tsx src/plugins/mcp-app/server.ts"
  },
  "keywords": [
    "adaptive-cards",
    "presentation",
    "slides",
    "schema",
    "json-schema",
    "mcp",
    "mcp-app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@mdx-js/react": "^3.1.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "gh-pages": "^6.3.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "webpackbar": "7.0.0"
  }
}
