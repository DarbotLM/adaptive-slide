{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaptive-slide.dev/schemas/tiles/chart-tile.schema.json",
  "title": "Chart Tile",
  "description": "A tile for rendering data visualizations, including bar graphs, line graphs, pie charts, donut charts, area charts, and scatter plots.",
  "type": "object",
  "required": ["type", "data"],
  "allOf": [
    { "$ref": "../tile.schema.json#/$defs/TileBase" },
    {
      "if": {
        "properties": {
          "type": { "const": "Tile.Chart" }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["chartType"]
      }
    }
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "Tile.Chart",
        "Tile.BarGraph",
        "Tile.PieChart",
        "Tile.DonutChart",
        "Tile.LineGraph",
        "Tile.AreaChart",
        "Tile.ScatterPlot"
      ],
      "description": "Tile.Chart is the generic chart element. Semantic aliases infer chartType when omitted."
    },
    "chartType": {
      "type": "string",
      "enum": [
        "bar",
        "bargraph",
        "horizontalBar",
        "line",
        "linegraph",
        "pie",
        "piechart",
        "donut",
        "donutchart",
        "area",
        "areachart",
        "scatter",
        "scatterplot"
      ],
      "description": "Type of chart to render"
    },
    "title": {
      "type": "string",
      "description": "Chart title"
    },
    "data": {
      "$ref": "#/$defs/ChartData"
    },
    "showLegend": {
      "type": "boolean",
      "default": true
    },
    "showGrid": {
      "type": "boolean",
      "default": true
    },
    "colors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Custom color palette for data series"
    },
    "aspectRatio": {
      "type": "string",
      "pattern": "^\\d+:\\d+$",
      "default": "16:9"
    },
    "orientation": {
      "type": "string",
      "enum": ["vertical", "horizontal"],
      "default": "vertical",
      "description": "Bar graph orientation"
    },
    "holeSize": {
      "type": "number",
      "minimum": 0,
      "maximum": 80,
      "default": 45,
      "description": "Donut chart inner hole size as a percentage of radius"
    }
  },
  "unevaluatedProperties": false,
  "$defs": {
    "ChartData": {
      "type": "object",
      "required": ["labels", "datasets"],
      "properties": {
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Category labels (x-axis for bar/line)"
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["values"],
            "properties": {
              "label": { "type": "string" },
              "values": {
                "type": "array",
                "items": { "type": "number" }
              },
              "color": { "type": "string" }
            }
          },
          "minItems": 1
        }
      }
    }
  }
}
